# Firebase (replace with your project values)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Developer-only: comma-separated emails that can see Advanced Settings (payment/API keys).
# Only list emails you (the developer) use; do not add business owner or employees.
# Example: VITE_ADVANCED_SETTINGS_EMAILS=dev@yourcompany.com
VITE_ADVANCED_SETTINGS_EMAILS=

# Debug Tools: password to unlock أدوات التطوير (invite admin, reset data, etc.). Only you should know it.
VITE_DEBUG_TOOLS_PASSWORD=
