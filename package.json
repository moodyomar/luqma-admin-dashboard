{
  "name": "luqma-admin-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Multi-tenant restaurant admin dashboard with Firebase",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "sync:firestore-tenant-rules": "bash scripts/sync-firebase-tenant-rules.sh",
    "sync:firestore-tenant-rules:dry": "bash scripts/sync-firebase-tenant-rules.sh --dry-run",
    "rules:copy-luqma-to-deploy": "cp firebase-rules/luqma.rules firestore.rules && echo 'firestore.rules ← luqma.rules (review then: firebase deploy --only firestore:rules)'",
    "dev": "vite",
    "build": "vite build",
    "build:production": "npm run ensure:advanced-settings-env && vite build",
    "ensure:advanced-settings-env": "node scripts/ensure-advanced-settings-env.js",
    "verify:build": "node scripts/verify-build-advanced-settings.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "firebase": "^11.9.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.5"
  }
}
